# GitHub personal access token. Jangan gunakan awalan VITE_ karena token harus
# tetap berada di server dan tidak boleh masuk ke bundle browser.
GITHUB_TOKEN="github_pat_xxxxxxxxxxxxxxxxxxxx"

# Opsional. Jika diisi, hanya repositori publik milik username ini yang diambil.
# Jika kosong, endpoint /user/repos dipakai dan dapat menyertakan repo private.
GITHUB_USERNAME="lelxzyy"

# Groq API key untuk AI Assistant. Variabel ini hanya dibaca di server.
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxx"

# Opsional. Default: llama-3.3-70b-versatile
GROQ_MODEL="llama-3.3-70b-versatile"
